-- Void me (BodyPosition) - maintien continu

local player = game.Players.LocalPlayer

local function setupCharacter(character)
    local humanoid = character:WaitForChild("Humanoid")
    local rootPart = character:WaitForChild("HumanoidRootPart")

    local voiding = false
    local voidStopSignal = nil

    local function ensureTPOnPart(part, position)
        -- si un TPForce existe dÃ©jÃ , on met Ã  jour ses propriÃ©tÃ©s, sinon on le crÃ©e
        local bp = part:FindFirstChild("TPForce")
        if bp and bp:IsA("BodyPosition") then
            bp.MaxForce = Vector3.new(1e7, 1e7, 1e7)
            bp.Position = position
            bp.D = 5000
            bp.P = 1e6
        else
            if bp then bp:Destroy() end
            bp = Instance.new("BodyPosition")
            bp.Name = "TPForce"
            bp.MaxForce = Vector3.new(1e7, 1e7, 1e7)
            bp.Position = position
            bp.D = 5000
            bp.P = 1e6
            bp.Parent = part
        end
    end

    local function startVoidLoop()
        if voiding then return end
        voiding = true
        voidStopSignal = Instance.new("BindableEvent")

        task.wait(1.5) -- dÃ©lai avant le dÃ©but du maintien (comme demandÃ©)

        local position = Vector3.new(0, -1000, 0)

        -- boucle qui restaure les BodyPositions rÃ©guliÃ¨rement
        task.spawn(function()
            while voiding and character.Parent do
                -- pour chaque partie : dÃ©sactiver collisions et s'assurer du BodyPosition
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        pcall(function()
                            part.CanCollide = false
                            part.Velocity = Vector3.new(0,0,0)
                            part.RotVelocity = Vector3.new(0,0,0)
                            ensureTPOnPart(part, position)
                        end)
                    end
                end

                -- court dÃ©lai : frÃ©quence de "rÃ©paration" si Roblox essaye de corriger
                -- tu peux baisser (0.05) pour Ãªtre plus agressif ou augmenter si besoin
                local finished = voidStopSignal.Event:Wait(0.08)
                if finished then break end
            end

            -- nettoyage : supprimer tous les TPForce restants (au cas oÃ¹)
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    local bp = part:FindFirstChild("TPForce")
                    if bp and bp:IsA("BodyPosition") then
                        pcall(function() bp:Destroy() end)
                    end
                    pcall(function() part.CanCollide = true end)
                end
            end
        end)
    end

    local function stopVoidLoop()
        if not voiding then return end
        voiding = false
        if voidStopSignal then
            pcall(function() voidStopSignal:Fire() end)
            pcall(function() voidStopSignal:Destroy() end)
            voidStopSignal = nil
        end
    end

    -- si on est dÃ©jÃ  en ragdoll, lancer ; sinon Ã©couter StateChanged
    if humanoid:GetState() == Enum.HumanoidStateType.Physics then
        startVoidLoop()
    end

    local stateConn
    stateConn = humanoid.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Physics then
            startVoidLoop()
        end
    end)

    -- arrÃªter si le joueur meurt
    local diedConn
    diedConn = humanoid.Died:Connect(function()
        stopVoidLoop()
    end)

    -- si Character disparaÃ®t (respawn), nettoyer connexions
    character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            stopVoidLoop()
            if stateConn then stateConn:Disconnect() end
            if diedConn then diedConn:Disconnect() end
        end
    end)
end

-- Appliquer au personnage actuel
if player.Character then
    setupCharacter(player.Character)
end

-- RÃ©applique aprÃ¨s respawn
player.CharacterAdded:Connect(function(char)
    setupCharacter(char)
end)
