local function script1()
-- Loop KawaiiRevolver (sans equipement)
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Obtenez les services nécessaires
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Liste des noms de joueurs à cibler (DisplayName)
local targetPlayerNames = {}

-- Liste des usernames à ignorer (jamais attaqués)
local ignoredUsernames = {
    solterrman = true,
    solterreman2 = true,
    angel = true
}

-- Nom de l'outil à utiliser
local ToolName = "Kawaii Revolver"

-- Crée l'interface utilisateur
local ScreenGui = Instance.new("ScreenGui")
local TextBox = Instance.new("TextBox")
local AddButton = Instance.new("TextButton")
local RemoveButton = Instance.new("TextButton")
local SuggestionsFrame = Instance.new("Frame")

-- Configure ScreenGui
ScreenGui.Parent = game.CoreGui

-- Configure TextBox pour entrer le nom du joueur
TextBox.Parent = ScreenGui
TextBox.Size = UDim2.new(0, 200, 0, 30)
TextBox.Position = UDim2.new(1, -220, 0, 10) -- En haut à droite
TextBox.PlaceholderText = "Entrer le nom du joueur"
TextBox.Text = ""
TextBox.TextSize = 14

-- Configure le bouton "Fixe"
AddButton.Parent = ScreenGui
AddButton.Size = UDim2.new(0, 100, 0, 30)
AddButton.Position = UDim2.new(1, -120, 0, 50)
AddButton.Text = "Fixe"
AddButton.TextSize = 14

-- Configure le bouton "Unfixe"
RemoveButton.Parent = ScreenGui
RemoveButton.Size = UDim2.new(0, 100, 0, 30)
RemoveButton.Position = UDim2.new(1, -230, 0, 50)
RemoveButton.Text = "Unfixe"
RemoveButton.TextSize = 14

-- Configure le cadre des suggestions
SuggestionsFrame.Parent = ScreenGui
SuggestionsFrame.Size = UDim2.new(0, 200, 0, 100)
SuggestionsFrame.Position = UDim2.new(1, -220, 0, 90)
SuggestionsFrame.BackgroundTransparency = 0.5
SuggestionsFrame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
SuggestionsFrame.Visible = false

-- Fonction pour obtenir le joueur cible par son nom d'affichage
local function GetPlayerByName(displayName)
    for _, player in pairs(Players:GetPlayers()) do
        if player.DisplayName == displayName then
            return player
        end
    end
    return nil
end

-- Action du bouton "Fixe" pour ajouter un joueur à la liste
AddButton.MouseButton1Click:Connect(function()
    local enteredName = TextBox.Text
    if enteredName ~= "" and not table.find(targetPlayerNames, enteredName) then
        local player = GetPlayerByName(enteredName)
        if player and not ignoredUsernames[player.Name] then
            table.insert(targetPlayerNames, enteredName)
        end
        TextBox.Text = ""
    end
end)

-- Action du bouton "Unfixe" pour retirer un joueur de la liste
RemoveButton.MouseButton1Click:Connect(function()
    local enteredName = TextBox.Text
    if enteredName ~= "" then
        for i, name in ipairs(targetPlayerNames) do
            if name == enteredName then
                table.remove(targetPlayerNames, i)
                break
            end
        end
        TextBox.Text = ""
    end
end)

-- Fonction pour appliquer les dégâts avec l'outil "Kawaii Revolver"
local function applyDamageToPlayer(targetPlayer)
    local Humanoid = targetPlayer.Character:FindFirstChild("Humanoid")
    if Humanoid then
        local Tool = LocalPlayer.Backpack:FindFirstChild(ToolName)
        if Tool then
            Tool.Parent = LocalPlayer.Character

            -- Rendre le tool invisible
            for _, desc in ipairs(Tool:GetDescendants()) do
                if desc:IsA("BasePart") then
                    desc.Transparency = 1
                    desc.CanCollide = false
                elseif desc:IsA("Decal") then
                    desc.Transparency = 1
                end
            end
        end

        Tool = LocalPlayer.Character:FindFirstChild(ToolName)
        if Tool then
            local DamageRemote = Tool:FindFirstChild("DamageRemote")
            if DamageRemote then
                DamageRemote:FireServer(Humanoid)
            end
            -- Remet l'outil dans le backpack immédiatement après
            Tool.Parent = LocalPlayer.Backpack
        end
    end
end

-- Fonction pour gérer la boucle d'attaque
local function attackLoop()
    while true do
        for _, targetName in ipairs(targetPlayerNames) do
            local targetPlayer = GetPlayerByName(targetName)

            -- Vérifications complètes + protection des usernames ignorés
            if targetPlayer
            and not ignoredUsernames[targetPlayer.Name]
            and targetPlayer.Character
            and targetPlayer.Character:FindFirstChild("Humanoid") then

                local humanoid = targetPlayer.Character.Humanoid

                while humanoid.Health > 0 do
                    applyDamageToPlayer(targetPlayer)
                    task.wait(1)

                    -- Re-vérification continue
                    if not targetPlayer
                    or ignoredUsernames[targetPlayer.Name]
                    or not targetPlayer.Character
                    or not targetPlayer.Character:FindFirstChild("Humanoid") then
                        break
                    end
                end
            end
        end
        task.wait(0.2)
    end
end

-- Fonction pour mettre à jour les suggestions
local function updateSuggestions(inputText)
    for _, child in ipairs(SuggestionsFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end

    if inputText == "" then
        SuggestionsFrame.Visible = false
        return
    end

    SuggestionsFrame.Visible = true
    local yOffset = 0

    for _, player in ipairs(Players:GetPlayers()) do
        if player.DisplayName:lower():find(inputText:lower()) then
            local SuggestionButton = Instance.new("TextButton")
            SuggestionButton.Size = UDim2.new(1, 0, 0, 20)
            SuggestionButton.Position = UDim2.new(0, 0, 0, yOffset)
            SuggestionButton.Text = player.DisplayName
            SuggestionButton.TextScaled = true
            SuggestionButton.TextColor3 = Color3.new(1, 1, 1)
            SuggestionButton.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
            SuggestionButton.BorderSizePixel = 0
            SuggestionButton.Parent = SuggestionsFrame

            SuggestionButton.MouseButton1Click:Connect(function()
                TextBox.Text = player.DisplayName
                updateSuggestions("")
            end)

            yOffset = yOffset + 25
        end
    end
end

-- Détecter les changements dans le TextBox
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    updateSuggestions(TextBox.Text)
end)

-- Lancer la boucle d'attaque en arrière-plan
task.spawn(attackLoop)
end

local function script2()
-- Void me (BodyPosition) - maintien continu

local player = game.Players.LocalPlayer

local function setupCharacter(character)
    local humanoid = character:WaitForChild("Humanoid")
    local rootPart = character:WaitForChild("HumanoidRootPart")

    local voiding = false
    local voidStopSignal = nil

    local function ensureTPOnPart(part, position)
        -- si un TPForce existe dÃ©jÃ , on met Ã  jour ses propriÃ©tÃ©s, sinon on le crÃ©e
        local bp = part:FindFirstChild("TPForce")
        if bp and bp:IsA("BodyPosition") then
            bp.MaxForce = Vector3.new(1e7, 1e7, 1e7)
            bp.Position = position
            bp.D = 5000
            bp.P = 1e6
        else
            if bp then bp:Destroy() end
            bp = Instance.new("BodyPosition")
            bp.Name = "TPForce"
            bp.MaxForce = Vector3.new(1e7, 1e7, 1e7)
            bp.Position = position
            bp.D = 5000
            bp.P = 1e6
            bp.Parent = part
        end
    end

    local function startVoidLoop()
        if voiding then return end
        voiding = true
        voidStopSignal = Instance.new("BindableEvent")

        task.wait(1.5) -- dÃ©lai avant le dÃ©but du maintien (comme demandÃ©)

        local position = Vector3.new(0, -1000, 0)

        -- boucle qui restaure les BodyPositions rÃ©guliÃ¨rement
        task.spawn(function()
            while voiding and character.Parent do
                -- pour chaque partie : dÃ©sactiver collisions et s'assurer du BodyPosition
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        pcall(function()
                            part.CanCollide = false
                            part.Velocity = Vector3.new(0,0,0)
                            part.RotVelocity = Vector3.new(0,0,0)
                            ensureTPOnPart(part, position)
                        end)
                    end
                end

                -- court dÃ©lai : frÃ©quence de "rÃ©paration" si Roblox essaye de corriger
                -- tu peux baisser (0.05) pour Ãªtre plus agressif ou augmenter si besoin
                local finished = voidStopSignal.Event:Wait(0.08)
                if finished then break end
            end

            -- nettoyage : supprimer tous les TPForce restants (au cas oÃ¹)
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    local bp = part:FindFirstChild("TPForce")
                    if bp and bp:IsA("BodyPosition") then
                        pcall(function() bp:Destroy() end)
                    end
                    pcall(function() part.CanCollide = true end)
                end
            end
        end)
    end

    local function stopVoidLoop()
        if not voiding then return end
        voiding = false
        if voidStopSignal then
            pcall(function() voidStopSignal:Fire() end)
            pcall(function() voidStopSignal:Destroy() end)
            voidStopSignal = nil
        end
    end

    -- si on est dÃ©jÃ  en ragdoll, lancer ; sinon Ã©couter StateChanged
    if humanoid:GetState() == Enum.HumanoidStateType.Physics then
        startVoidLoop()
    end

    local stateConn
    stateConn = humanoid.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Physics then
            startVoidLoop()
        end
    end)

    -- arrÃªter si le joueur meurt
    local diedConn
    diedConn = humanoid.Died:Connect(function()
        stopVoidLoop()
    end)

    -- si Character disparaÃ®t (respawn), nettoyer connexions
    character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            stopVoidLoop()
            if stateConn then stateConn:Disconnect() end
            if diedConn then diedConn:Disconnect() end
        end
    end)
end

-- Appliquer au personnage actuel
if player.Character then
    setupCharacter(player.Character)
end

-- RÃ©applique aprÃ¨s respawn
player.CharacterAdded:Connect(function(char)
    setupCharacter(char)
end)
end

script1()
script2()
